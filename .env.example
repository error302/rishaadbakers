# ─── Rishaad Baker's — Environment Variables ──────────────────────────
# Copy this file to .env and fill in real values for production.
# All keys below are REQUIRED unless marked OPTIONAL.

# ─── Database ────────────────────────────────────────────────────────
# SQLite for local dev (default):
DATABASE_URL=file:./db/custom.db
# Postgres for production (recommended):
# DATABASE_URL=postgresql://user:password@host:5432/rishaad_bakers?schema=public

# ─── Auth ────────────────────────────────────────────────────────────
# REQUIRED. Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=change-me-to-a-strong-random-string

# REQUIRED. The public URL of your deployed site.
NEXTAUTH_URL=http://localhost:3000

# ─── Admin password ──────────────────────────────────────────────────
# OPTIONAL. If set, the seed script will create the admin user with this password.
# If blank, defaults to 'admin123' — ONLY for local dev. Set a strong password in prod.
ADMIN_PASSWORD=

# ─── Stripe (OPTIONAL — leave blank to disable online payments) ──────
# When all three are set, the checkout flow uses Stripe Checkout.
# When blank, orders are created as 'pay on delivery/cash'.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Email (OPTIONAL — leave blank to log to console instead) ────────
# Recommended: Resend — 3,000 free emails/month, no SMTP needed.
# When set, order confirmations + lead alerts are sent automatically.
RESEND_API_KEY=
EMAIL_FROM="Rishaad Baker's <hello@rishaadbakers.com>"

# ─── Error monitoring (OPTIONAL — leave blank to log to console) ─────
# Recommended: Sentry — free tier covers most small businesses.
SENTRY_DSN=

# ─── Rate limiting (OPTIONAL — leave blank for in-memory limiter) ────
# Recommended for production: Upstash Redis (free tier: 10k commands/day).
# When blank, an in-memory limiter is used (resets on server restart,
# not shared across instances — fine for single-server deploys).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
